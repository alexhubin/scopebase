APP_ENV=development
APP_NAME=ScopeBase API
SECRET_KEY=replace-with-at-least-32-random-characters
DATABASE_URL=postgresql+asyncpg://scopebase:scopebase@postgres:5432/scopebase
FRONTEND_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PUBLIC_LINK_TTL_DAYS=30
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
COOKIE_SECURE=false
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=ScopeBase <noreply@scopebase.local>
STORAGE_PROVIDER=minio
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=scopebase
S3_SECRET_KEY=scopebase-secret
S3_BUCKET=scopebase
S3_REGION=us-east-1
S3_AUTO_CREATE_BUCKET=true
MAX_UPLOAD_BYTES=10485760
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
BILLING_ADAPTER=local
DOMAIN=localhost

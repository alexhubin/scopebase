APP_ENV=production
APP_NAME=ScopeBase API
SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
POSTGRES_DB=scopebase
POSTGRES_USER=scopebase
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql+asyncpg://scopebase:replace-with-a-strong-database-password@postgres:5432/scopebase
FRONTEND_URL=https://scopebase.example.com
PUBLIC_APP_URL=https://scopebase.example.com
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PUBLIC_LINK_TTL_DAYS=30
CORS_ORIGINS=https://scopebase.example.com
COOKIE_SECURE=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=ScopeBase <noreply@example.com>
STORAGE_PROVIDER=r2
S3_ENDPOINT_URL=https://replace-with-account-id.r2.cloudflarestorage.com
S3_PUBLIC_ENDPOINT_URL=https://replace-with-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY=replace-with-an-r2-access-key-id
S3_SECRET_KEY=replace-with-an-r2-secret-access-key
S3_BUCKET=scopebase
S3_REGION=auto
S3_AUTO_CREATE_BUCKET=false
MAX_UPLOAD_BYTES=10485760
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
BILLING_ADAPTER=local
SCOPEBASE_HTTP_PORT=3080
SCOPEBASE_MAILPIT_PORT=8026
CADDY_NETWORK=caddy-proxy
